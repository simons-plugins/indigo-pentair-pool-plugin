<?xml version="1.0"?>
<Actions>
	<Action id="setPumpSpeed" deviceFilter="self.poolPump">
		<Name>Set Pump Speed (RPM)</Name>
		<CallbackMethod>setPumpSpeed</CallbackMethod>
		<ConfigUI>
			<Field id="speedLabel" type="label">
				<Label>Set the pump speed in RPM.</Label>
			</Field>
			<Field type="textfield" id="rpm" defaultValue="2400">
				<Label>RPM:</Label>
			</Field>
		</ConfigUI>
	</Action>

	<Action id="setPumpProgram" deviceFilter="self.poolPump">
		<Name>Set Pump Program</Name>
		<CallbackMethod>setPumpProgram</CallbackMethod>
		<ConfigUI>
			<Field id="programLabel" type="label">
				<Label>Set the pump to a pre-configured speed program.</Label>
			</Field>
			<Field type="menu" id="program" defaultValue="1">
				<Label>Program:</Label>
				<List>
					<Option value="1">Program 1</Option>
					<Option value="2">Program 2</Option>
					<Option value="3">Program 3</Option>
					<Option value="4">Program 4</Option>
				</List>
			</Field>
		</ConfigUI>
	</Action>

	<Action id="setChlorinatorOutput" deviceFilter="self.poolChlorinator">
		<Name>Set Chlorinator Output %</Name>
		<CallbackMethod>setChlorinatorOutput</CallbackMethod>
		<ConfigUI>
			<Field id="outputLabel" type="label">
				<Label>Set chlorination output percentage (0-100).</Label>
			</Field>
			<Field type="textfield" id="percent" defaultValue="50">
				<Label>Output %:</Label>
			</Field>
		</ConfigUI>
	</Action>

	<Action id="setSuperChlorinate" deviceFilter="self.poolChlorinator">
		<Name>Super Chlorinate</Name>
		<CallbackMethod>setSuperChlorinate</CallbackMethod>
		<ConfigUI>
			<Field id="superLabel" type="label">
				<Label>Enable or disable super chlorination.</Label>
			</Field>
			<Field type="checkbox" id="enabled" defaultValue="true">
				<Label>Enable super chlorinate: </Label>
			</Field>
		</ConfigUI>
	</Action>
</Actions>
