<?xml version="1.0"?>
<Devices>
	<!-- Pool Controller Coordinator — owns the MQTT connection (auto-created) -->
	<Device type="custom" id="poolController" allowUserCreation="false">
		<Name>Pool Controller</Name>
		<ConfigUI>
			<Field id="infoLabel" type="label" fontSize="small" fontColor="darkgray">
				<Label>This device is managed automatically. Configure MQTT settings in Plugins → Pentair Pool Controller → Configure.</Label>
			</Field>
		</ConfigUI>
		<UiDisplayStateId>mqttStatus</UiDisplayStateId>
		<States>
			<State id="mqttStatus">
				<ValueType>String</ValueType>
				<TriggerLabel>MQTT Status Changed</TriggerLabel>
				<ControlPageLabel>MQTT Status</ControlPageLabel>
			</State>
			<State id="controllerType">
				<ValueType>String</ValueType>
				<TriggerLabel>Controller Type Changed</TriggerLabel>
				<ControlPageLabel>Controller Type</ControlPageLabel>
			</State>
			<State id="airTemp">
				<ValueType>Number</ValueType>
				<TriggerLabel>Air Temperature Changed</TriggerLabel>
				<ControlPageLabel>Air Temp</ControlPageLabel>
			</State>
			<State id="lastMessage">
				<ValueType>String</ValueType>
				<TriggerLabel>Last Message Changed</TriggerLabel>
				<ControlPageLabel>Last Message</ControlPageLabel>
			</State>
		</States>
	</Device>

	<!-- Pool/Spa Body — thermostat with heating control (auto-created) -->
	<Device type="thermostat" id="poolBody" allowUserCreation="false">
		<Name>Pool Body</Name>
		<ConfigUI>
			<Field id="controllerId" type="textfield" hidden="true">
				<Label>Controller ID:</Label>
			</Field>
			<Field id="bodyId" type="textfield" hidden="true">
				<Label>Body ID:</Label>
			</Field>
		</ConfigUI>
		<States>
			<State id="bodyType">
				<ValueType>String</ValueType>
				<TriggerLabel>Body Type Changed</TriggerLabel>
				<ControlPageLabel>Body Type</ControlPageLabel>
			</State>
			<State id="heatStatus">
				<ValueType>String</ValueType>
				<TriggerLabel>Heat Status Changed</TriggerLabel>
				<ControlPageLabel>Heat Status</ControlPageLabel>
			</State>
		</States>
	</Device>

	<!-- Pool Circuit — relay on/off for equipment circuits (auto-created) -->
	<Device type="relay" id="poolCircuit" allowUserCreation="false">
		<Name>Pool Circuit</Name>
		<ConfigUI>
			<Field id="controllerId" type="textfield" hidden="true">
				<Label>Controller ID:</Label>
			</Field>
			<Field id="circuitId" type="textfield" hidden="true">
				<Label>Circuit ID:</Label>
			</Field>
		</ConfigUI>
		<States>
			<State id="circuitType">
				<ValueType>String</ValueType>
				<TriggerLabel>Circuit Type Changed</TriggerLabel>
				<ControlPageLabel>Circuit Type</ControlPageLabel>
			</State>
			<State id="circuitFunction">
				<ValueType>String</ValueType>
				<TriggerLabel>Circuit Function Changed</TriggerLabel>
				<ControlPageLabel>Function</ControlPageLabel>
			</State>
		</States>
	</Device>

	<!-- Pool Pump — IntelliFlo variable-speed pump (auto-created) -->
	<Device type="custom" id="poolPump" allowUserCreation="false">
		<Name>Pool Pump</Name>
		<ConfigUI>
			<Field id="controllerId" type="textfield" hidden="true">
				<Label>Controller ID:</Label>
			</Field>
			<Field id="pumpId" type="textfield" hidden="true">
				<Label>Pump ID:</Label>
			</Field>
		</ConfigUI>
		<UiDisplayStateId>rpm</UiDisplayStateId>
		<States>
			<State id="status">
				<ValueType>String</ValueType>
				<TriggerLabel>Pump Status Changed</TriggerLabel>
				<ControlPageLabel>Status</ControlPageLabel>
			</State>
			<State id="rpm">
				<ValueType>Number</ValueType>
				<TriggerLabel>RPM Changed</TriggerLabel>
				<ControlPageLabel>RPM</ControlPageLabel>
			</State>
			<State id="watts">
				<ValueType>Number</ValueType>
				<TriggerLabel>Watts Changed</TriggerLabel>
				<ControlPageLabel>Watts</ControlPageLabel>
			</State>
			<State id="gpm">
				<ValueType>Number</ValueType>
				<TriggerLabel>Flow Rate Changed</TriggerLabel>
				<ControlPageLabel>GPM</ControlPageLabel>
			</State>
			<State id="pumpType">
				<ValueType>String</ValueType>
				<TriggerLabel>Pump Type Changed</TriggerLabel>
				<ControlPageLabel>Pump Type</ControlPageLabel>
			</State>
			<State id="program">
				<ValueType>Number</ValueType>
				<TriggerLabel>Program Changed</TriggerLabel>
				<ControlPageLabel>Program</ControlPageLabel>
			</State>
		</States>
	</Device>

	<!-- Pool Chlorinator — IntelliChlor salt chlorinator (auto-created) -->
	<Device type="custom" id="poolChlorinator" allowUserCreation="false">
		<Name>Pool Chlorinator</Name>
		<ConfigUI>
			<Field id="controllerId" type="textfield" hidden="true">
				<Label>Controller ID:</Label>
			</Field>
			<Field id="chlorinatorId" type="textfield" hidden="true">
				<Label>Chlorinator ID:</Label>
			</Field>
		</ConfigUI>
		<UiDisplayStateId>saltPPM</UiDisplayStateId>
		<States>
			<State id="status">
				<ValueType>String</ValueType>
				<TriggerLabel>Chlorinator Status Changed</TriggerLabel>
				<ControlPageLabel>Status</ControlPageLabel>
			</State>
			<State id="saltPPM">
				<ValueType>Number</ValueType>
				<TriggerLabel>Salt Level Changed</TriggerLabel>
				<ControlPageLabel>Salt (PPM)</ControlPageLabel>
			</State>
			<State id="outputPercent">
				<ValueType>Number</ValueType>
				<TriggerLabel>Output % Changed</TriggerLabel>
				<ControlPageLabel>Output %</ControlPageLabel>
			</State>
			<State id="superChlorinate">
				<ValueType>Boolean</ValueType>
				<TriggerLabel>Super Chlorinate Changed</TriggerLabel>
				<ControlPageLabel>Super Chlorinate</ControlPageLabel>
			</State>
			<State id="targetOutput">
				<ValueType>Number</ValueType>
				<TriggerLabel>Target Output Changed</TriggerLabel>
				<ControlPageLabel>Target %</ControlPageLabel>
			</State>
		</States>
	</Device>

	<!-- Pool Chemistry — IntelliChem readings (auto-created) -->
	<Device type="sensor" id="poolChemistry" allowUserCreation="false">
		<Name>Pool Chemistry</Name>
		<ConfigUI>
			<Field id="controllerId" type="textfield" hidden="true">
				<Label>Controller ID:</Label>
			</Field>
			<Field id="chemControllerId" type="textfield" hidden="true">
				<Label>Chemistry Controller ID:</Label>
			</Field>
		</ConfigUI>
		<States>
			<State id="pH">
				<ValueType>Number</ValueType>
				<TriggerLabel>pH Changed</TriggerLabel>
				<ControlPageLabel>pH</ControlPageLabel>
			</State>
			<State id="pHSetpoint">
				<ValueType>Number</ValueType>
				<TriggerLabel>pH Setpoint Changed</TriggerLabel>
				<ControlPageLabel>pH Setpoint</ControlPageLabel>
			</State>
			<State id="orp">
				<ValueType>Number</ValueType>
				<TriggerLabel>ORP Changed</TriggerLabel>
				<ControlPageLabel>ORP (mV)</ControlPageLabel>
			</State>
			<State id="orpSetpoint">
				<ValueType>Number</ValueType>
				<TriggerLabel>ORP Setpoint Changed</TriggerLabel>
				<ControlPageLabel>ORP Setpoint</ControlPageLabel>
			</State>
			<State id="saturationIndex">
				<ValueType>Number</ValueType>
				<TriggerLabel>Saturation Index Changed</TriggerLabel>
				<ControlPageLabel>Saturation Index</ControlPageLabel>
			</State>
			<State id="acidTankLevel">
				<ValueType>Number</ValueType>
				<TriggerLabel>Acid Tank Changed</TriggerLabel>
				<ControlPageLabel>Acid Tank %</ControlPageLabel>
			</State>
			<State id="baseTankLevel">
				<ValueType>Number</ValueType>
				<TriggerLabel>Base Tank Changed</TriggerLabel>
				<ControlPageLabel>Base Tank %</ControlPageLabel>
			</State>
		</States>
	</Device>
</Devices>
