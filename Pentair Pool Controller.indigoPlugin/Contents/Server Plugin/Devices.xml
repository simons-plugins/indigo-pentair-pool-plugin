<?xml version="1.0"?>
<Devices>
	<!-- Pool Controller Coordinator — owns the MQTT connection -->
	<Device type="custom" id="poolController" allowUserCreation="true">
		<Name>Pool Controller</Name>
		<ConfigUI>
			<Field id="brokerHost" type="textfield" defaultValue="localhost">
				<Label>MQTT Broker Host:</Label>
			</Field>
			<Field id="brokerPort" type="textfield" defaultValue="1883">
				<Label>MQTT Broker Port:</Label>
			</Field>
			<Field id="mqttUsername" type="textfield" defaultValue="">
				<Label>Username (optional):</Label>
			</Field>
			<Field id="mqttPassword" type="textfield" defaultValue="" secure="true">
				<Label>Password (optional):</Label>
			</Field>
			<Field id="sep1" type="separator"/>
			<Field id="rootTopic" type="textfield" defaultValue="pool">
				<Label>MQTT Root Topic:</Label>
			</Field>
			<Field id="topicHelp" type="label" fontSize="small" fontColor="darkgray" alignWithControl="true">
				<Label>The root topic configured in nodejs-poolController (default: "pool").</Label>
			</Field>
		</ConfigUI>
		<UiDisplayStateId>mqttStatus</UiDisplayStateId>
		<States>
			<State id="mqttStatus">
				<ValueType>String</ValueType>
				<TriggerLabel>MQTT Status Changed</TriggerLabel>
				<ControlPageLabel>MQTT Status</ControlPageLabel>
			</State>
			<State id="controllerType">
				<ValueType>String</ValueType>
				<TriggerLabel>Controller Type Changed</TriggerLabel>
				<ControlPageLabel>Controller Type</ControlPageLabel>
			</State>
			<State id="airTemp">
				<ValueType>Number</ValueType>
				<TriggerLabel>Air Temperature Changed</TriggerLabel>
				<ControlPageLabel>Air Temp</ControlPageLabel>
			</State>
			<State id="lastMessage">
				<ValueType>String</ValueType>
				<TriggerLabel>Last Message Changed</TriggerLabel>
				<ControlPageLabel>Last Message</ControlPageLabel>
			</State>
		</States>
	</Device>

	<!-- Pool/Spa Body — thermostat with heating control -->
	<Device type="thermostat" id="poolBody" allowUserCreation="true">
		<Name>Pool Body</Name>
		<ConfigUI>
			<Field id="controllerId" type="menu">
				<Label>Pool Controller:</Label>
				<List class="self" filter="self.poolController" method="getControllerList" dynamicReload="true"/>
			</Field>
			<Field id="bodyId" type="menu" defaultValue="1">
				<Label>Body:</Label>
				<List>
					<Option value="1">Pool</Option>
					<Option value="2">Spa</Option>
				</List>
			</Field>
		</ConfigUI>
		<States>
			<State id="bodyType">
				<ValueType>String</ValueType>
				<TriggerLabel>Body Type Changed</TriggerLabel>
				<ControlPageLabel>Body Type</ControlPageLabel>
			</State>
			<State id="heatStatus">
				<ValueType>String</ValueType>
				<TriggerLabel>Heat Status Changed</TriggerLabel>
				<ControlPageLabel>Heat Status</ControlPageLabel>
			</State>
		</States>
	</Device>

	<!-- Pool Circuit — relay on/off for equipment circuits -->
	<Device type="relay" id="poolCircuit" allowUserCreation="true">
		<Name>Pool Circuit</Name>
		<ConfigUI>
			<Field id="controllerId" type="menu">
				<Label>Pool Controller:</Label>
				<List class="self" filter="self.poolController" method="getControllerList" dynamicReload="true"/>
			</Field>
			<Field id="circuitId" type="textfield" defaultValue="">
				<Label>Circuit ID:</Label>
			</Field>
			<Field id="circuitIdHelp" type="label" fontSize="small" fontColor="darkgray" alignWithControl="true">
				<Label>The circuit number from nodejs-poolController (e.g. 1, 2, 6).</Label>
			</Field>
		</ConfigUI>
		<States>
			<State id="circuitType">
				<ValueType>String</ValueType>
				<TriggerLabel>Circuit Type Changed</TriggerLabel>
				<ControlPageLabel>Circuit Type</ControlPageLabel>
			</State>
			<State id="circuitFunction">
				<ValueType>String</ValueType>
				<TriggerLabel>Circuit Function Changed</TriggerLabel>
				<ControlPageLabel>Function</ControlPageLabel>
			</State>
		</States>
	</Device>
</Devices>
